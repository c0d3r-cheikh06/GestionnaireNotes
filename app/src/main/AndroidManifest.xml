<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".ApplicationNotes"
        android:allowBackup="true"
        android:icon="@mipmap/icone_application"
        android:label="@string/nom_application"
        android:roundIcon="@mipmap/icone_application_ronde"
        android:supportsRtl="true"
        android:theme="@style/Theme.GestionnaireNotes">

        <activity
            android:name=".ActivitePrincipale"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ActiviteFormulaireNote"
            android:exported="false" />

    </application>

</manifest>
